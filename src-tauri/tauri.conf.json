{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CodeReader",
  "version": "1.0.0-rc.1",
  "identifier": "com.codereader.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeReader",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "worker-src": "'self' blob:"
      },
      "devCsp": {
        "default-src": "'self' http://127.0.0.1:1420",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420",
        "font-src": "'self' data: http://127.0.0.1:1420",
        "img-src": "'self' asset: http://asset.localhost blob: data: http://127.0.0.1:1420",
        "script-src": "'self' http://127.0.0.1:1420",
        "style-src": "'self' 'unsafe-inline' http://127.0.0.1:1420",
        "worker-src": "'self' blob: http://127.0.0.1:1420"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "useLocalToolsDir": true,
    "publisher": "CodeReader Project",
    "category": "DeveloperTool",
    "copyright": "Copyright 2026 CodeReader contributors",
    "shortDescription": "Local-first AI-assisted code and Markdown reader.",
    "longDescription": "CodeReader helps people inspect local source trees, read code and Markdown, generate bounded reviewable explanations, retain reading progress, and detect stale explanations after files change.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "startMenuFolder": "CodeReader",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      },
      "wix": {
        "version": "1.0.0",
        "upgradeCode": "9cd436e5-1c0f-592b-bc46-2b507e245b2d",
        "language": "zh-CN"
      }
    }
  }
}

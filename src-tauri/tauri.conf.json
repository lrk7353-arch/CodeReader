{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CodeReader",
  "version": "0.1.0",
  "identifier": "com.codereader.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeReader",
        "width": 1280,
        "height": 820,
        "minWidth": 960,

{
  "name": "codereader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs --host 127.0.0.1 --port 1420 --force",
    "build": "node scripts/build.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1 --port 4173",
    "tauri": "node scripts/tauri.mjs",
    "cargo:check": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-check.ps1",
    "cargo:test": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-test.ps1",
    "cargo:clippy": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-clippy.ps1",
    "test": "node scripts/test.mjs",
    "doctor": "node scripts/check-environment.mjs",
    "repair:native": "node scripts/repair-native-deps.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "1.17.0",
    "monaco-editor": "0.53.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}

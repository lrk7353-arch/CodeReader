{
  "name": "codereader",
  "version": "0.11.0-beta.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs --host 127.0.0.1 --port 1420 --force",
    "build": "node scripts/build.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1 --port 4173",
    "tauri": "node scripts/tauri.mjs",
    "cargo:check": "node scripts/cargo.mjs check",
    "cargo:test": "node scripts/cargo.mjs test",
    "cargo:clippy": "node scripts/cargo.mjs clippy",
    "lint": "node scripts/lint.mjs",
    "format": "node scripts/format.mjs --write",
    "format:check": "node scripts/format.mjs --check",
    "test": "node scripts/test.mjs",
    "doctor": "node scripts/check-environment.mjs",
    "doctor:linux": "node scripts/linux-dev-doctor.mjs",
    "repair:native": "node scripts/repair-native-deps.mjs",
    "icons:generate": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "release:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/release-windows.ps1",
    "verify:signature": "node scripts/verify-authenticode.mjs",
    "verify:linux": "node scripts/verify-linux-dev.mjs",
    "evidence:linux": "node scripts/verify-linux-dev.mjs --json --output artifacts/linux-evidence/verify-linux.json",
    "smoke:linux-desktop": "node scripts/linux-desktop-smoke.mjs",
    "smoke:windows-release": "node scripts/windows-release-smoke.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "1.17.0",
    "monaco-editor": "0.53.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
